# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical site URL for auth email redirects (production)
NEXT_PUBLIC_SITE_URL=https://zarcfit.vercel.app

# Server-only (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: local psql migrations (run-migrations.sh)
SUPABASE_DB_PASSWORD=

# Food search API (USDA FoodData Central)
USDA_FDC_API_KEY=

# Stripe (Phase 10 — billing)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# Health import webhook (optional shared secret)
HEALTH_IMPORT_SECRET=
