# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical site URL for auth email redirects (production)
NEXT_PUBLIC_SITE_URL=https://zarcfit.vercel.app

# Server-only (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: local psql migrations (run-migrations.sh)
SUPABASE_DB_PASSWORD=

# Food search API (USDA FoodData Central)
USDA_FDC_API_KEY=

# Stripe billing — see STRIPE_SETUP.md for Dashboard setup
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PRICE_STARTER=
NEXT_PUBLIC_STRIPE_PRICE_GROWTH=
NEXT_PUBLIC_STRIPE_PRICE_PRO=
# Server-side fallbacks (optional)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

# Health import webhook shared secret
HEALTH_IMPORT_SECRET=

# Email notifications (Resend) — server only
RESEND_API_KEY=
RESEND_FROM_EMAIL=ZarcFit <notifications@zarcfit.com>

# Internal API secret for server-to-server calls (notifications/send-email)
INTERNAL_API_SECRET=

# AI generation (server only — optional; rules/skeleton mode works without a key)
OPENAI_API_KEY=

# Playwright E2E (optional)
PLAYWRIGHT_BASE_URL=http://localhost:3000
# E2E_TRAINER_EMAIL=
# E2E_TRAINER_PASSWORD=
